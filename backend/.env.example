# Hermes/Mariyam backend — пример переменных окружения
# Копировать в backend/.env и заполнить реальными значениями.
# Секреты НЕ хранятся в коде и не коммитятся (SECURITY_PRIVACY.md, раздел 19).
#
# ЗАПОЛНИТЬ ОБЯЗАТЕЛЬНО (без значения по умолчанию — weak fallback запрещён):
POSTGRES_PASSWORD=<PUT_STRONG_DB_PASSWORD_HERE>
# Host port для docker-compose (слушает только 127.0.0.1)
BACKEND_HOST_PORT=8000

# PostgreSQL connection string (использует backend/config.py и server.py)
# Для docker-compose: postgresql://hermes:hermes@hermes_mariyam_postgres:5432/hermes
# Для локального запуска: postgresql://hermes:<POSTGRES_PASSWORD>@localhost:5432/hermes
DATABASE_URL=postgresql://hermes:hermes@localhost:5432/hermes

# Настройки MCP-транспорта (раздел 16):
#   stdio  — Hermes запускает backend как subprocess (по умолчанию, рекомендуется на VPS)
#   http   — backend слушает HTTP на localhost (docker-compose / удалённый Hermes)
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# --- Ниже секреты для Hermes-профиля (НЕ бэкенда). Для справки. ---
# Telegram Bot Token (Этап 1) — задаётся в конфиге Hermes profile, не здесь.
# TELEGRAM_BOT_TOKEN=
# STT/TTS/LM API keys (Этап 3) — в конфиге Hermes profile / .env Hermes.
# ELEVENLABS_API_KEY=
# OPENAI_API_KEY=
# OpenWeather / Aladhan — ключи для weather/prayer tools (Этап 6), если нужны.
# OPENWEATHER_API_KEY=
